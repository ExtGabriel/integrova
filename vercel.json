{
  "buildCommand": null,
  "outputDirectory": "CFE INSIGHT/App",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://integrova-production-0e08.up.railway.app/api/:path*"
    },
    {
      "source": "/",
      "destination": "/pages/login.html"
    },
    {
      "source": "/:path*",
      "destination": "/pages/:path*"
    }
  ]
}
