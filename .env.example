# Supabase Configuration
# Obtener de: https://app.supabase.com/project/_/settings/api

# URL del proyecto Supabase (públia)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave ANON (pública - segura para frontend)
VITE_SUPABASE_ANON_KEY=tu_clave_anon_aqui

# API Base URL (producción)
# En Vercel, usar el dominio del proyecto
VITE_API_BASE_URL=https://tu-dominio.vercel.app

# ⚠️ SOLO PARA BACKEND (NO INCLUIR EN FRONTEND) ⚠️
# Clave SERVICE_ROLE (privada - NUNCA exponer en código frontend)
SUPABASE_SERVICE_ROLE_KEY=tu_clave_service_role_aqui
