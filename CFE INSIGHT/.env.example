# CFE INSIGHT - Variables de Entorno
# Copia este archivo a .env y completa con tus valores reales

# Puerto del servidor
PORT=3001

# Supabase Configuration
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# OpenAI API Configuration
OPENAI_API_KEY=sk-tu_api_key_de_openai_aqui

# Modo de Operación
NODE_ENV=development
DEMO_MODE=false

# Configuración de Seguridad (opcional)
SESSION_SECRET=genera_un_string_aleatorio_seguro
JWT_SECRET=genera_otro_string_aleatorio_seguro

# CORS Configuration (opcional)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Rate Limiting (opcional)
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000
